FROM node:22-alpine

WORKDIR /app

RUN corepack enable

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json tsconfig.base.json ./
COPY apps/web/package.json ./apps/web/package.json
COPY packages/shared-types/package.json ./packages/shared-types/package.json
COPY packages/orchestrator-core/package.json ./packages/orchestrator-core/package.json

RUN pnpm install --frozen-lockfile --prod=false

COPY apps/web ./apps/web
COPY packages/shared-types ./packages/shared-types
COPY packages/orchestrator-core ./packages/orchestrator-core

RUN pnpm --filter @codesymphony/shared-types build

EXPOSE 5173

CMD ["pnpm", "--filter", "@codesymphony/web", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]
