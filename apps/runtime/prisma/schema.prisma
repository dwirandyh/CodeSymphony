generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64", "darwin"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum WorktreeStatus {
  active
  archived
  creating
  create_failed
  deleting
  delete_failed
}

enum ChatRole {
  user
  assistant
  system
}

enum ChatEventType {
  message_delta
  tool_started
  tool_output
  tool_finished
  permission_requested
  permission_resolved
  question_requested
  question_answered
  question_dismissed
  plan_created
  plan_approved
  plan_dismissed
  plan_revision_requested
  subagent_started
  subagent_finished
  chat_completed
  chat_failed
}

enum ChatThreadKind {
  default
  review
}

enum ChatMode {
  default
  plan
}

enum ChatQueuedMessageStatus {
  queued
  dispatch_requested
  dispatching
}

enum ChatThreadPermissionProfile {
  default
  review_git
}

enum ChatThreadPermissionMode {
  default
  full_access
}

enum CliAgent {
  claude
  codex
  cursor
  opencode
}

enum AutomationRunStatus {
  queued
  dispatching
  running
  waiting_input
  succeeded
  failed
  canceled
  skipped
}

enum AutomationTriggerKind {
  manual
  schedule
}

model Repository {
  id            String     @id @default(cuid())
  name          String
  rootPath      String     @unique
  defaultBranch String
  setupScript    String?
  teardownScript String?
  runScript      String?
  saveAutomation String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  worktrees     Worktree[]
  automations   Automation[]
  automationRuns AutomationRun[]
}

model Worktree {
  id             String         @id @default(cuid())
  repositoryId   String
  branch         String
  path           String         @unique
  baseBranch     String
  status         WorktreeStatus @default(active)
  lastCreateError String?
  lastDeleteError String?
  branchRenamed  Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  repository Repository   @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  threads    ChatThread[]
  automations Automation[]
  automationRuns AutomationRun[]

  @@unique([repositoryId, branch])
  @@index([repositoryId])
}

model ChatThread {
  id                  String                      @id @default(cuid())
  worktreeId          String
  title               String
  kind                ChatThreadKind              @default(default)
  permissionProfile   ChatThreadPermissionProfile @default(default)
  permissionMode      ChatThreadPermissionMode    @default(default)
  mode                ChatMode                    @default(default)
  titleEditedManually Boolean                     @default(false)
  agent               CliAgent                    @default(claude)
  model               String                      @default("claude-sonnet-4-6")
  modelProviderId     String?
  pendingPlanEventId  String?
  pendingPlanFilePath String?
  pendingPlanContent  String?
  handoffSourceThreadId String?
  handoffSourcePlanEventId String?
  claudeSessionId     String?
  codexSessionId      String?
  cursorSessionId     String?
  opencodeSessionId   String?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  worktree      Worktree       @relation(fields: [worktreeId], references: [id], onDelete: Cascade)
  modelProvider ModelProvider? @relation(fields: [modelProviderId], references: [id], onDelete: SetNull)
  messages      ChatMessage[]
  events        ChatEvent[]
  queuedMessages ChatQueuedMessage[]
  automationRuns AutomationRun[]

  @@index([worktreeId])
  @@index([worktreeId, kind, createdAt])
  @@index([modelProviderId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  threadId  String
  seq       Int
  role      ChatRole
  content   String
  createdAt DateTime @default(now())

  thread      ChatThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  attachments ChatAttachment[]

  @@unique([threadId, seq])
  @@index([threadId])
}

model ChatAttachment {
  id          String   @id @default(cuid())
  messageId   String
  filename    String
  mimeType    String
  sizeBytes   Int
  content     String   // text content for text files, empty for images
  storagePath String?  // filesystem path for images
  source      String   // "file_picker" | "drag_drop" | "clipboard_text" | "clipboard_image"
  createdAt   DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  @@index([messageId])
}

model ChatQueuedMessage {
  id                  String                  @id @default(cuid())
  threadId            String
  seq                 Int
  content             String
  mode                ChatMode                @default(default)
  status              ChatQueuedMessageStatus @default(queued)
  dispatchRequestedAt DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  thread      ChatThread               @relation(fields: [threadId], references: [id], onDelete: Cascade)
  attachments ChatQueuedAttachment[]

  @@unique([threadId, seq])
  @@index([threadId, status, dispatchRequestedAt, seq])
}

model ChatQueuedAttachment {
  id              String   @id @default(cuid())
  queuedMessageId  String
  filename         String
  mimeType         String
  sizeBytes        Int
  content          String
  storagePath      String?
  source           String
  createdAt        DateTime @default(now())

  queuedMessage ChatQueuedMessage @relation(fields: [queuedMessageId], references: [id], onDelete: Cascade)

  @@index([queuedMessageId])
}

model ChatEvent {
  id        String        @id @default(cuid())
  threadId  String
  idx       Int
  type      ChatEventType
  payload   Json
  createdAt DateTime      @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([threadId, idx])
  @@index([threadId])
}

model ModelProvider {
  id        String   @id @default(cuid())
  agent     CliAgent @default(claude)
  name      String
  modelId   String   @default("")
  baseUrl   String?
  apiKey    String?
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  threads ChatThread[]
  automations Automation[]

  @@index([agent, isActive])
}

model AppSettings {
  id        String   @id @default("singleton")
  modelId   String   @default("")
  updatedAt DateTime @updatedAt
}

model Automation {
  id              String                   @id @default(cuid())
  repositoryId    String
  targetWorktreeId String
  name            String
  prompt          String
  agent           CliAgent                 @default(claude)
  model           String                   @default("claude-sonnet-4-6")
  modelProviderId String?
  permissionMode  ChatThreadPermissionMode @default(default)
  chatMode        ChatMode                 @default(default)
  enabled         Boolean                  @default(true)
  rrule           String
  timezone        String
  dtstart         DateTime
  nextRunAt       DateTime
  lastRunAt       DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  repository     Repository            @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  targetWorktree Worktree              @relation(fields: [targetWorktreeId], references: [id], onDelete: Cascade)
  modelProvider  ModelProvider?        @relation(fields: [modelProviderId], references: [id], onDelete: SetNull)
  runs           AutomationRun[]
  promptVersions AutomationPromptVersion[]

  @@index([repositoryId])
  @@index([targetWorktreeId])
  @@index([enabled, nextRunAt])
}

model AutomationRun {
  id          String                @id @default(cuid())
  automationId String
  repositoryId String
  worktreeId  String
  threadId    String?
  status      AutomationRunStatus
  triggerKind AutomationTriggerKind
  scheduledFor DateTime
  startedAt   DateTime?
  finishedAt  DateTime?
  error       String?
  summary     String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  automation  Automation            @relation(fields: [automationId], references: [id], onDelete: Cascade)
  repository  Repository            @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  worktree    Worktree              @relation(fields: [worktreeId], references: [id], onDelete: Cascade)
  thread      ChatThread?           @relation(fields: [threadId], references: [id], onDelete: SetNull)

  @@unique([automationId, scheduledFor])
  @@index([automationId, createdAt])
  @@index([threadId])
  @@index([status])
}

model AutomationPromptVersion {
  id                   String      @id @default(cuid())
  automationId         String
  content              String
  source               String
  restoredFromVersionId String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  automation          Automation                @relation(fields: [automationId], references: [id], onDelete: Cascade)
  restoredFromVersion AutomationPromptVersion?  @relation("AutomationPromptVersionRestore", fields: [restoredFromVersionId], references: [id], onDelete: SetNull)
  restoredVersions    AutomationPromptVersion[] @relation("AutomationPromptVersionRestore")

  @@index([automationId, updatedAt])
}
