generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum WorktreeStatus {
  active
  archived
}

enum ChatRole {
  user
  assistant
  system
}

enum ChatEventType {
  message_delta
  tool_started
  tool_output
  tool_finished
  permission_requested
  permission_resolved
  question_requested
  question_answered
  plan_created
  plan_approved
  plan_revision_requested
  chat_completed
  chat_failed
}

model Repository {
  id            String     @id @default(cuid())
  name          String
  rootPath      String     @unique
  defaultBranch String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  worktrees     Worktree[]
}

model Worktree {
  id           String         @id @default(cuid())
  repositoryId String
  branch       String
  path         String         @unique
  baseBranch   String
  status       WorktreeStatus @default(active)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  repository Repository   @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  threads    ChatThread[]

  @@unique([repositoryId, branch])
  @@index([repositoryId])
}

model ChatThread {
  id              String        @id @default(cuid())
  worktreeId      String
  title           String
  claudeSessionId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  worktree Worktree     @relation(fields: [worktreeId], references: [id], onDelete: Cascade)
  messages ChatMessage[]
  events   ChatEvent[]

  @@index([worktreeId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  threadId  String
  seq       Int
  role      ChatRole
  content   String
  createdAt DateTime @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([threadId, seq])
  @@index([threadId])
}

model ChatEvent {
  id        String        @id @default(cuid())
  threadId  String
  idx       Int
  type      ChatEventType
  payload   Json
  createdAt DateTime      @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([threadId, idx])
  @@index([threadId])
}
