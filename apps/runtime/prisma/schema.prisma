generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64", "darwin"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum WorktreeStatus {
  active
  archived
}

enum ChatRole {
  user
  assistant
  system
}

enum ChatEventType {
  message_delta
  thinking_delta
  tool_started
  tool_output
  tool_finished
  permission_requested
  permission_resolved
  question_requested
  question_answered
  question_dismissed
  plan_created
  plan_approved
  plan_revision_requested
  subagent_started
  subagent_finished
  chat_completed
  chat_failed
}

enum ChatThreadKind {
  default
  review
}

enum ChatThreadPermissionProfile {
  default
  review_git
}

model Repository {
  id            String     @id @default(cuid())
  name          String
  rootPath      String     @unique
  defaultBranch String
  setupScript    String?
  teardownScript String?
  runScript      String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  worktrees     Worktree[]
}

model Worktree {
  id             String         @id @default(cuid())
  repositoryId   String
  branch         String
  path           String         @unique
  baseBranch     String
  status         WorktreeStatus @default(active)
  branchRenamed  Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  repository Repository   @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  threads    ChatThread[]

  @@unique([repositoryId, branch])
  @@index([repositoryId])
}

model ChatThread {
  id                  String                      @id @default(cuid())
  worktreeId          String
  title               String
  kind                ChatThreadKind             @default(default)
  permissionProfile   ChatThreadPermissionProfile @default(default)
  titleEditedManually Boolean                     @default(false)
  claudeSessionId     String?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  worktree Worktree      @relation(fields: [worktreeId], references: [id], onDelete: Cascade)
  messages ChatMessage[]
  events   ChatEvent[]

  @@index([worktreeId])
  @@index([worktreeId, kind, createdAt])
}

model ChatMessage {
  id        String   @id @default(cuid())
  threadId  String
  seq       Int
  role      ChatRole
  content   String
  createdAt DateTime @default(now())

  thread      ChatThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  attachments ChatAttachment[]

  @@unique([threadId, seq])
  @@index([threadId])
}

model ChatAttachment {
  id          String   @id @default(cuid())
  messageId   String
  filename    String
  mimeType    String
  sizeBytes   Int
  content     String   // text content for text files, empty for images
  storagePath String?  // filesystem path for images
  source      String   // "file_picker" | "drag_drop" | "clipboard_text" | "clipboard_image"
  createdAt   DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  @@index([messageId])
}

model ChatEvent {
  id        String        @id @default(cuid())
  threadId  String
  idx       Int
  type      ChatEventType
  payload   Json
  createdAt DateTime      @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([threadId, idx])
  @@index([threadId])
}

model ModelProvider {
  id        String   @id @default(cuid())
  name      String
  modelId   String   @default("")
  baseUrl   String
  apiKey    String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppSettings {
  id        String   @id @default("singleton")
  modelId   String   @default("")
  updatedAt DateTime @updatedAt
}
