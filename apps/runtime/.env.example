RUNTIME_HOST=0.0.0.0
# For multi-worktree: make setup-worktree PORT=4322
RUNTIME_PORT=4331
DATABASE_URL="file:./dev.db"
CLAUDE_CODE_EXECUTABLE=claude
WORKTREE_ROOT="~/.codesymphony/worktrees"

# Device sidecars
ANDROID_WS_SCRCPY_BASE_URL="http://127.0.0.1:8765/"
# Example: ANDROID_WS_SCRCPY_COMMAND="cd /path/to/ws-scrcpy/dist && npm run script:dist:start"
ANDROID_WS_SCRCPY_COMMAND=
# AutoFlowLabs/ws-scrcpy custom build expects Basic Auth on the sidecar itself.
# CodeSymphony proxies these credentials server-side so the browser does not need to log in.
ADMIN_USER=
ADMIN_PASSWORD=
IOS_BRIDGE_BASE_URL="http://127.0.0.1:8000"
# Example: IOS_BRIDGE_COMMAND="uvx --from ios-bridge-cli ios-bridge start-server --host 127.0.0.1 --port 8000"
IOS_BRIDGE_COMMAND=
# Optional: override the local ScreenCaptureKit + VideoToolbox helper.
# Example: IOS_SIMULATOR_BRIDGE_COMMAND="swift run --package-path ../simulator-bridge SimulatorBridge"
IOS_SIMULATOR_BRIDGE_COMMAND=
IOS_SIMULATOR_BRIDGE_FPS=60
DEVICE_REFRESH_INTERVAL_MS=5000
