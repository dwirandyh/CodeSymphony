{
  "name": "@codesymphony/runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null || true",
    "predev": "pnpm exec prisma migrate deploy && pnpm --filter @codesymphony/shared-types build && pnpm --filter @codesymphony/chat-timeline-core build",
    "prebuild": "pnpm --filter @codesymphony/shared-types build && pnpm --filter @codesymphony/chat-timeline-core build",
    "dev": "tsx watch --env-file .env src/index.ts",
    "prestart": "pnpm exec prisma migrate deploy && pnpm --filter @codesymphony/shared-types build && pnpm --filter @codesymphony/chat-timeline-core build",
    "start": "tsx --env-file .env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "DATABASE_URL=\"file:./test.db\" prisma migrate deploy && vitest run --config vitest.config.ts",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.42",
    "@codesymphony/chat-timeline-core": "workspace:*",
    "@codesymphony/shared-types": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.2.0",
    "@opencode-ai/sdk": "^1.14.20",
    "@prisma/client": "^6.4.1",
    "fastify": "^5.2.1",
    "node-pty": "^1.1.0",
    "prisma": "^6.4.1",
    "ws": "^8.18.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
