{
  "name": "@codesymphony/runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @codesymphony/shared-types build",
    "dev": "tsx watch --env-file .env src/index.ts",
    "prestart": "pnpm --filter @codesymphony/shared-types build",
    "start": "tsx --env-file .env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "DATABASE_URL=\"file:./test.db\" prisma migrate deploy && vitest run --config vitest.config.ts",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.42",
    "@codesymphony/shared-types": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@prisma/client": "^6.4.1",
    "fastify": "^5.2.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "prisma": "^6.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
