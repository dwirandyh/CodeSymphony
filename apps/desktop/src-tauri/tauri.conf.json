{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeSymphony",
  "version": "0.1.0",
  "identifier": "com.codesymphony.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @codesymphony/web exec vite --port 5174 --strictPort",
    "beforeBuildCommand": "pnpm --filter @codesymphony/web build",
    "devUrl": "http://127.0.0.1:5174",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "CodeSymphony",
        "width": 1280,
        "height": 820,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "acceptFirstMouse": true,
        "backgroundColor": "#191d24",
        "visible": false,
        "useHttpsScheme": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:4321 ws://127.0.0.1:4321 http://localhost:4321 ws://localhost:4321 http://127.0.0.1:4322 ws://127.0.0.1:4322 http://localhost:4322 ws://localhost:4322; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: http://127.0.0.1:4321 http://localhost:4321 http://127.0.0.1:4322 http://localhost:4322"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/node"
    ],
    "resources": [
      "runtime-bundle/**/*"
    ]
  }
}
