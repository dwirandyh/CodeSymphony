{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeSymphony",
  "version": "0.1.0",
  "identifier": "com.codesymphony.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @codesymphony/web dev",
    "beforeBuildCommand": "pnpm --filter @codesymphony/web build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "CodeSymphony",
        "width": 1280,
        "height": 820,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:4321 ws://127.0.0.1:4321; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/node"],
    "resources": ["runtime-bundle/**/*"]
  }
}
